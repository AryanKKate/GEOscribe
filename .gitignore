# ==========================================
# 1. Server-Side / Flask (server/ folder)
# ==========================================
# Virtual environments
server/venv/
server/env/
server/ENV/

# Python bytecode & cache
**/__pycache__/
**/*.py[cod]
**/*$py.class

# AI Model Weights (Essential for VisioNiX)
# Prevents large .pt (PyTorch) or .h5 (Keras) files from bloating Git
server/models/*.pt
server/models/*.pth
server/models/*.h5
server/weights/

# Local uploads/logs
server/uploads/
server/logs/


# ==========================================
# 2. Client-Side / Next.js (client/ folder)
# ==========================================
# Dependencies
client/node_modules/

# Next.js build output
client/.next/
client/out/
client/build/

# Frontend logs
client/npm-debug.log*
client/yarn-error.log*


# ==========================================
# 3. Security & Secrets (Global)
# ==========================================
# Never commit your Supabase or LLM keys!
.env
.env.local
.env.development.local
.env.production.local
**/.env*


# ==========================================
# 4. System & Editor Files
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.sublime-project
*.sublime-workspace